+        # Merge extras captured at validation time but unknown to the
+        # class-level serializer (e.g. model_validate(..., extra='allow') on
+        # a model with extra='forbid' or 'ignore'). Without this, values
+        # stored on __pydantic_extra__ silently disappear on dump.
+        extra = getattr(self, '__pydantic_extra__', None)
+        if extra and isinstance(result, dict):
